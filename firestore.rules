rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leads
    // Fields: name, industry, website, status, userId, createdAt
    //
    // Collection: research
    // Fields: leadId, platform, content, sourceUrl, userId, createdAt
    //
    // Collection: criteria
    // Fields: name, description, weight, userId
    //
    // Collection: services
    // Fields: name, description, userId
    //
    // Collection: evaluations
    // Fields: leadId, score, insights, criteriaScores, userId, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAssigned() {
      return isAuthenticated() && (
        (resource.data.assignedToUid == request.auth.uid) ||
        (resource.data.assignedToEmail == request.auth.token.email)
      );
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }

    function isValidLead(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             (!('industry' in data) || data.industry is string || data.industry == null) &&
             (!('website' in data) || data.website is string || data.website == null) &&
             data.status in ['new', 'researching', 'evaluated', 'contacted'] &&
             data.userId == request.auth.uid &&
             (!('assignedToEmail' in data) || data.assignedToEmail is string || data.assignedToEmail == null) &&
             (!('assignedToUid' in data) || data.assignedToUid is string || data.assignedToUid == null) &&
             (!('createdByEmail' in data) || data.createdByEmail is string || data.createdByEmail == null) &&
             (!('createdAt' in data) || data.createdAt is string || data.createdAt == null);
    }

    function isValidResearch(data) {
      return data.leadId is string &&
             data.platform is string && data.platform.size() > 0 &&
             data.content is string && data.content.size() > 0 &&
             data.userId == request.auth.uid &&
             (!('sourceUrl' in data) || data.sourceUrl is string || data.sourceUrl == null) &&
             (!('createdByEmail' in data) || data.createdByEmail is string || data.createdByEmail == null) &&
             (!('createdAt' in data) || data.createdAt is string || data.createdAt == null);
    }

    function isValidCriterion(data) {
      return data.name is string && data.name.size() > 0 &&
             data.weight is number && data.weight >= 0 && data.weight <= 1 &&
             data.userId == request.auth.uid &&
             (!('description' in data) || data.description is string || data.description == null) &&
             (!('leadId' in data) || data.leadId is string || data.leadId == null) &&
             (!('createdByEmail' in data) || data.createdByEmail is string || data.createdByEmail == null);
    }

    function isValidService(data) {
      return data.name is string && data.name.size() > 0 &&
             data.userId == request.auth.uid &&
             (!('description' in data) || data.description is string || data.description == null) &&
             (!('createdByEmail' in data) || data.createdByEmail is string || data.createdByEmail == null);
    }

    function isValidEvaluation(data) {
      return data.leadId is string &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             data.userId == request.auth.uid &&
             (!('insights' in data) || data.insights is string || data.insights == null) &&
             (!('criteriaScores' in data) || data.criteriaScores is map || data.criteriaScores == null) &&
             (!('createdByEmail' in data) || data.createdByEmail is string || data.createdByEmail == null) &&
             (!('createdAt' in data) || data.createdAt is string || data.createdAt == null);
    }

    function isValidSavedAsset(data) {
      return data.leadId is string &&
             data.type in ['email', 'deck'] &&
             data.content is string && data.content.size() > 0 &&
             data.userId == request.auth.uid &&
             (!('createdByEmail' in data) || data.createdByEmail is string || data.createdByEmail == null) &&
             (!('createdAt' in data) || data.createdAt is string || data.createdAt == null);
    }

    function isValidTask(data) {
      return data.leadId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 500 &&
             data.status in ['todo', 'in-progress', 'done'] &&
             (!('dueDate' in data) || data.dueDate is string || data.dueDate == null) &&
             data.userId == request.auth.uid &&
             (!('assignedToEmail' in data) || data.assignedToEmail is string || data.assignedToEmail == null) &&
             (!('assignedToUid' in data) || data.assignedToUid is string || data.assignedToUid == null) &&
             (!('createdByEmail' in data) || data.createdByEmail is string || data.createdByEmail == null) &&
             (!('createdAt' in data) || data.createdAt is string || data.createdAt == null);
    }

    function isValidUserProfile(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.displayName is string &&
             (!('photoURL' in data) || data.photoURL is string || data.photoURL == null) &&
             data.lastLogin is string;
    }

    match /leads/{leadId} {
      allow read: if isDocOwner() || isAssigned();
      allow create: if isAuthenticated() && isValidLead(request.resource.data);
      allow update: if (isDocOwner() || isAssigned()) && isValidLead(request.resource.data) && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /research/{researchId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidResearch(request.resource.data);
      allow update: if isDocOwner() && isValidResearch(request.resource.data) && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /criteria/{criterionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidCriterion(request.resource.data);
      allow update: if isDocOwner() && isValidCriterion(request.resource.data) && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /services/{serviceId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidService(request.resource.data);
      allow update: if isDocOwner() && isValidService(request.resource.data) && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /evaluations/{evaluationId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidEvaluation(request.resource.data);
      allow update: if isDocOwner() && isValidEvaluation(request.resource.data) && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /savedAssets/{assetId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && isValidSavedAsset(request.resource.data);
      allow update: if isDocOwner() && isValidSavedAsset(request.resource.data) && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /tasks/{taskId} {
      allow read: if isDocOwner() || isAssigned();
      allow create: if isAuthenticated() && isValidTask(request.resource.data);
      allow update: if (isDocOwner() || isAssigned()) && isValidTask(request.resource.data) && uidUnchanged();
      allow delete: if isDocOwner();
    }

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(uid) && isValidUserProfile(request.resource.data);
    }
  }
}

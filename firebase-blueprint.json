{
  "entities": {
    "Lead": {
      "title": "Lead",
      "description": "A company or potential customer to research.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Company name" },
        "industry": { "type": "string", "description": "Industry category" },
        "website": { "type": "string", "description": "Company website URL" },
        "status": { "type": "string", "enum": ["new", "researching", "evaluated", "contacted"], "description": "Current status of the lead" },
        "userId": { "type": "string", "description": "Owner of the lead" },
        "assignedToEmail": { "type": "string", "description": "Email of the assigned user" },
        "assignedToUid": { "type": "string", "description": "UID of the assigned user" },
        "createdByEmail": { "type": "string", "description": "Email of the creator" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "userId", "createdAt"]
    },
    "Research": {
      "title": "Research",
      "description": "Gathered facts and summaries about a company.",
      "type": "object",
      "properties": {
        "leadId": { "type": "string", "description": "Reference to the Lead" },
        "platform": { "type": "string", "description": "Source platform (e.g., LinkedIn, Blog)" },
        "content": { "type": "string", "description": "Summarized content" },
        "sourceUrl": { "type": "string", "description": "Original URL if available" },
        "userId": { "type": "string", "description": "Owner of the research" },
        "createdByEmail": { "type": "string", "description": "Email of the creator" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["leadId", "platform", "content", "userId", "createdAt"]
    },
    "Criterion": {
      "title": "Criterion",
      "description": "Evaluation criteria for company probability.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Criterion name" },
        "description": { "type": "string", "description": "What this criterion evaluates" },
        "weight": { "type": "number", "description": "Weight in the final score (0-1)" },
        "leadId": { "type": "string", "description": "Optional reference to a specific Lead" },
        "userId": { "type": "string", "description": "Owner of the criterion" },
        "createdByEmail": { "type": "string", "description": "Email of the creator" }
      },
      "required": ["name", "weight", "userId"]
    },
    "Service": {
      "title": "Service",
      "description": "Services offered by the sales team.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Service name" },
        "description": { "type": "string", "description": "Service details" },
        "userId": { "type": "string", "description": "Owner of the service" },
        "createdByEmail": { "type": "string", "description": "Email of the creator" }
      },
      "required": ["name", "userId"]
    },
    "Evaluation": {
      "title": "Evaluation",
      "description": "AI-generated evaluation and insights for a lead.",
      "type": "object",
      "properties": {
        "leadId": { "type": "string", "description": "Reference to the Lead" },
        "score": { "type": "number", "description": "Probability score (0-100)" },
        "insights": { "type": "string", "description": "Detailed AI insights" },
        "criteriaScores": { "type": "object", "description": "Breakdown of scores per criterion" },
        "userId": { "type": "string", "description": "Owner of the evaluation" },
        "createdByEmail": { "type": "string", "description": "Email of the creator" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["leadId", "score", "userId", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A task associated with a lead.",
      "type": "object",
      "properties": {
        "leadId": { "type": "string", "description": "Reference to the Lead" },
        "title": { "type": "string", "description": "Task title" },
        "dueDate": { "type": "string", "format": "date", "description": "Due date" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"], "description": "Current status" },
        "userId": { "type": "string", "description": "Owner of the task" },
        "assignedToEmail": { "type": "string", "description": "Email of the assigned user" },
        "assignedToUid": { "type": "string", "description": "UID of the assigned user" },
        "createdByEmail": { "type": "string", "description": "Email of the creator" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["leadId", "title", "status", "userId", "createdAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User UID" },
        "email": { "type": "string", "description": "User email" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User photo URL" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" }
      },
      "required": ["uid", "email", "displayName", "lastLogin"]
    },
    "SavedAsset": {
      "title": "SavedAsset",
      "description": "A generated email or deck for a lead.",
      "type": "object",
      "properties": {
        "leadId": { "type": "string", "description": "Reference to the Lead" },
        "type": { "type": "string", "enum": ["email", "deck"], "description": "Type of asset" },
        "content": { "type": "string", "description": "Content of the asset" },
        "userId": { "type": "string", "description": "Owner of the asset" },
        "createdByEmail": { "type": "string", "description": "Email of the creator" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["leadId", "type", "content", "userId", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": { "schema": "Lead", "description": "Company leads" },
    "/research/{researchId}": { "schema": "Research", "description": "Research data" },
    "/criteria/{criterionId}": { "schema": "Criterion", "description": "Evaluation criteria" },
    "/services/{serviceId}": { "schema": "Service", "description": "Sales services" },
    "/evaluations/{evaluationId}": { "schema": "Evaluation", "description": "Lead evaluations" },
    "/tasks/{taskId}": { "schema": "Task", "description": "Lead tasks" },
    "/savedAssets/{assetId}": { "schema": "SavedAsset", "description": "Generated emails and decks" },
    "/users/{uid}": { "schema": "UserProfile", "description": "User profiles" }
  }
}
